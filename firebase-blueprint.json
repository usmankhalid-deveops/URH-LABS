{
  "entities": {
    "User": {
      "title": "User",
      "description": "The user profile containing details of their subscription, credits remaining, and role.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "credits": { "type": "number", "description": "Character or query credits available" },
        "plan": { "type": "string", "description": "Free, 1M, 3M, 5M, or 11M Characters" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "credits", "plan", "role", "createdAt"]
    },
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "Represents each AI tool usage request and its produced output.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "tool": { "type": "string" },
        "request": { "type": "string" },
        "response": { "type": "string" },
        "creditsUsed": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "tool", "request", "response", "creditsUsed", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Active subscription records for user accounts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plan", "amount", "status", "createdAt"]
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "Manual pricing tier requests generated when a user uploads an Easypaisa/JazzCash transcript screen.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "screenshotUrl", "status", "createdAt"]
    },
    "ClonedVoice": {
      "title": "ClonedVoice",
      "description": "Custom voice clone blueprints saved by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Neutral"] },
        "archetype": { "type": "string" },
        "pitch": { "type": "number" },
        "speed": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "description", "gender", "archetype", "pitch", "speed", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public and private user details indexed by Firebase Auth uid"
    },
    "users/{userId}/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Aggregated tool request actions"
    },
    "users/{userId}/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "List of purchase records"
    },
    "users/{userId}/cloned_voices/{voiceId}": {
      "schema": "ClonedVoice",
      "description": "Custom user-specific speech clone profiles"
    },
    "payment_requests/{requestId}": {
      "schema": "PaymentRequest",
      "description": "Administrative payment screenshots to approve credits manually"
    }
  }
}
